# ============================================================
# .env.example - Environment Variables Documentation
# Copy this file to .env and fill in your values
# ============================================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password_here
DB_NAME=club_manager
DB_CONNECTION_LIMIT=10
DB_MULTIPLE_STATEMENTS=true

# Session
SESSION_SECRET=your_session_secret_here
SESSION_COOKIE_MAX_AGE=604800000

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=Your Club <noreply@example.com>

# Application
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
APP_UPLOAD_DIR=./uploads
APP_REPORT_DIR=./reports
APP_MAX_FILE_SIZE=5242880
APP_NAME=Club Manager v3
CLUB_NAME=Your Club Name
CLUB_ADDRESS=Your Club Address
CLUB_PHONE=Your Club Phone
CLUB_EMAIL=contact@yourclub.example.com
APP_SEASON=2024-2025

# Subscriptions
SUB_ANNUAL_ADULT=280
SUB_ANNUAL_JUNIOR=150
SUB_ANNUAL_FAMILY=450
SUB_MONTHLY_ADULT=30
SUB_TRIAL=0
SUB_LICENCE_FEE=45

# Paths
PATH_REPORTS=/var/www/club_manager/reports
PATH_BACKUPS=/var/www/club_manager/backups
PATH_UPLOADS=/var/www/club_manager/uploads
PATH_TEMP=/tmp/club_uploads

# Features
FEATURE_ONLINE_PAYMENT=false
FEATURE_SMS_NOTIF=false
FEATURE_ADVANCED_REPORTS=true
FEATURE_MEMBER_PORTAL=true
FEATURE_MOBILE_APP=false
