<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><title><%= title %></title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container main-content">
  <ol class="breadcrumb"><li><a href="/teams">Équipes</a></li><li><a href="/teams/<%= team.id %>"><%= team.name %></a></li><li class="active">Stats</li></ol>
  <h2>Statistiques - <%= team.name %></h2>
  <div class="row">
    <div class="col-md-3"><div class="panel panel-primary"><div class="panel-body text-center"><h2><%= team.matchesPlayed %></h2><p>Matchs joués</p></div></div></div>
    <div class="col-md-3"><div class="panel panel-success"><div class="panel-body text-center"><h2><%= team.wins %></h2><p>Victoires</p></div></div></div>
    <div class="col-md-3"><div class="panel panel-warning"><div class="panel-body text-center"><h2><%= team.draws %></h2><p>Nuls</p></div></div></div>
    <div class="col-md-3"><div class="panel panel-danger"><div class="panel-body text-center"><h2><%= team.losses %></h2><p>Défaites</p></div></div></div>
  </div>
  <div class="row">
    <div class="col-md-6"><div class="panel panel-default"><div class="panel-body text-center"><h3><%= team.goalsFor %></h3><p>Buts marqués</p></div></div></div>
    <div class="col-md-6">
      <% var total = team.matchesPlayed || 1; %>
      <div class="panel panel-default"><div class="panel-body">
        <p>Taux de victoire : <strong><%= Math.round(team.wins / total * 100) %>%</strong></p>
        <div class="progress">
          <div class="progress-bar progress-bar-success" style="width:<%= Math.round(team.wins/total*100) %>%"><%= team.wins %>V</div>
          <div class="progress-bar progress-bar-warning" style="width:<%= Math.round(team.draws/total*100) %>%"><%= team.draws %>N</div>
          <div class="progress-bar progress-bar-danger"  style="width:<%= Math.round(team.losses/total*100) %>%"><%= team.losses %>D</div>
        </div>
      </div></div>
    </div>
  </div>
  <a href="/teams/<%= team.id %>" class="btn btn-default">&larr; Retour équipe</a>
</div>
<script src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>
