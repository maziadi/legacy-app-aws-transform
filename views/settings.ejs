<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><title>Paramètres</title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container main-content">
  <h2>Paramètres</h2>
  <% if (typeof flash !== 'undefined' && flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'warning' %> alert-dismissible">
    <button class="close" data-dismiss="alert">&times;</button><%= flash.msg %>
  </div>
  <% } %>
  <div class="alert alert-warning">
    <strong>Note :</strong> Les paramètres sont actuellement stockés dans <code>config.js</code> et non en base de données.
    La modification via cette interface n'est pas encore implémentée (TODO depuis v3).
  </div>
  <div class="panel panel-default">
    <div class="panel-heading">Informations club</div>
    <div class="panel-body">
      <form method="POST" action="/settings">
        <div class="form-group"><label>Nom du club</label><input type="text" class="form-control" value="<%= config.clubName %>" disabled></div>
        <div class="form-group"><label>Saison</label><input type="text" class="form-control" value="<%= config.season %>" disabled></div>
        <div class="form-group"><label>Email</label><input type="text" class="form-control" value="<%= config.clubEmail %>" disabled></div>
        <div class="form-group"><label>Téléphone</label><input type="text" class="form-control" value="<%= config.clubPhone %>" disabled></div>
        <div class="form-group"><label>Adresse</label><input type="text" class="form-control" value="<%= config.clubAddress %>" disabled></div>
        <button type="submit" class="btn btn-primary" disabled>Enregistrer (non implémenté)</button>
        <small class="text-muted"> Modifier directement config.js sur le serveur</small>
      </form>
    </div>
  </div>
</div>
<script src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>
