<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><title>Installations</title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container-fluid main-content">
  <div class="page-header">
    <h2><i class="fa fa-building"></i> Installations sportives
      <a href="/facilities/new" class="btn btn-success btn-sm pull-right"><i class="fa fa-plus"></i> Nouvelle</a>
    </h2>
  </div>
  <div class="row">
    <% (facilities || []).forEach(function(f) { %>
    <div class="col-sm-6 col-md-4">
      <div class="panel panel-<%= f.is_available ? 'default' : 'danger' %>">
        <div class="panel-heading">
          <h3 class="panel-title">
            <i class="fa fa-<%= f.type === 'field' ? 'flag' : f.type === 'gym' ? 'building' : f.type === 'pool' ? 'tint' : 'home' %>"></i>
            <%= f.name %>
            <span class="pull-right"><span class="badge"><%= f.type %></span></span>
          </h3>
        </div>
        <div class="panel-body" style="font-size:13px">
          <p>
            <strong>Capacité :</strong> <%= f.capacity %> pers. &bull;
            <strong>Tarif :</strong> <%= f.hourly_rate > 0 ? f.hourly_rate + '€/h' : 'Gratuit' %>
          </p>
          <% if (f.address) { %><p><i class="fa fa-map-marker"></i> <%= f.address %></p><% } %>
          <% if (!f.is_available) { %><p class="text-danger"><i class="fa fa-times-circle"></i> Indisponible</p><% } %>
          <% if (f.next_booking) { %>
          <p><strong>Prochain créneau :</strong> <%= f.next_booking.start_time ? f.next_booking.start_time.substring(0,16).replace('T',' ') : '-' %></p>
          <% } %>
        </div>
        <div class="panel-footer">
          <a href="/facilities/<%= f.id %>" class="btn btn-xs btn-default">Voir</a>
          <a href="/facilities/<%= f.id %>/schedule" class="btn btn-xs btn-info">Planning</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<script src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>
