<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><title><%= title %></title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container-fluid main-content">
  <div class="page-header">
    <h2><i class="fa fa-euro"></i> Paiements
      <a href="/payments/new" class="btn btn-success btn-sm pull-right"><i class="fa fa-plus"></i> Nouveau</a>
      <a href="/payments/export/csv?season=<%= filters.season %>" class="btn btn-default btn-sm pull-right" style="margin-right:5px"><i class="fa fa-download"></i> CSV</a>
      <a href="/payments/overdue" class="btn btn-warning btn-sm pull-right" style="margin-right:5px"><i class="fa fa-exclamation-triangle"></i> En retard</a>
    </h2>
  </div>

  <form method="GET" action="/payments" class="form-inline" style="margin-bottom:15px">
    <select name="season" class="form-control input-sm">
      <% (seasons || []).forEach(function(s) { %>
      <option value="<%= s %>" <%= filters.season === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
    <select name="status" class="form-control input-sm">
      <option value="">Tous statuts</option>
      <option value="paid"      <%= filters.status === 'paid'      ? 'selected' : '' %>>Payé</option>
      <option value="pending"   <%= filters.status === 'pending'   ? 'selected' : '' %>>En attente</option>
      <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Annulé</option>
    </select>
    <button type="submit" class="btn btn-primary btn-sm">Filtrer</button>
  </form>

  <div class="row" style="margin-bottom:15px">
    <div class="col-md-3"><div class="panel panel-success panel-sm"><div class="panel-body"><strong><%= totalPaid %> €</strong><br><small>Total encaissé</small></div></div></div>
    <div class="col-md-3"><div class="panel panel-warning panel-sm"><div class="panel-body"><strong><%= totalPending %> €</strong><br><small>Total en attente</small></div></div></div>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <table class="table table-striped table-hover table-condensed">
    <thead>
      <tr><th>#</th><th>Membre</th><th>Montant</th><th>Type</th><th>Méthode</th><th>Date</th><th>Statut</th><th>Saison</th><th></th></tr>
    </thead>
    <tbody>
      <% (payments || []).forEach(function(p) { %>
      <tr>
        <td><small>#<%= p.id %></small></td>
        <td>
          <a href="/members/<%= p.member_id %>"><%= p.member_name || (p.first_name + ' ' + p.last_name) %></a>
          <% if (p.migrated_from_excel) { %><span class="label label-default" title="Migré Excel">XLS</span><% } %>
        </td>
        <td><strong><%= p.amount %> €</strong></td>
        <td><small><%= p.payment_type %></small></td>
        <td><small><%= p.payment_method %></small></td>
        <td><small><%= p.payment_date || '-' %></small></td>
        <td>
          <span class="label label-<%= p.status === 'paid' ? 'success' : p.status === 'pending' ? 'warning' : 'default' %>">
            <%= p.status %>
          </span>
        </td>
        <td><small><%= p.season || '-' %></small></td>
        <td><a href="/payments/<%= p.id %>" class="btn btn-xs btn-default"><i class="fa fa-eye"></i></a></td>
      </tr>
      <% }) %>
      <% if (!payments || payments.length === 0) { %>
      <tr><td colspan="9" class="text-center text-muted" style="padding:20px">Aucun paiement</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<script src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>
