<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><title>Paiements en retard</title>
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container-fluid main-content">
  <div class="page-header">
    <h2><i class="fa fa-exclamation-triangle text-danger"></i> Paiements en retard
      <small>Total: <%= total %> €</small>
    </h2>
  </div>
  <% if (typeof flash !== 'undefined' && flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'info' %> alert-dismissible">
    <button class="close" data-dismiss="alert">&times;</button><%= flash.msg %>
  </div>
  <% } %>
  <form method="POST" action="/payments/send-reminders" style="margin-bottom:15px">
    <button type="submit" class="btn btn-warning" onclick="return confirm('Envoyer les rappels par email à tous ?')">
      <i class="fa fa-envelope"></i> Envoyer rappels email (<%= (payments || []).length %> membres)
    </button>
  </form>
  <table class="table table-striped table-hover">
    <thead><tr><th>Membre</th><th>Email</th><th>Tél.</th><th>Montant</th><th>Échéance</th><th>Description</th><th></th></tr></thead>
    <tbody>
      <% (payments || []).forEach(function(p) { %>
      <tr class="danger">
        <td><a href="/members/<%= p.member_id %>"><%= p.first_name %> <%= p.last_name %></a></td>
        <td><a href="mailto:<%= p.email %>"><%= p.email %></a></td>
        <td><%= p.phone || '-' %></td>
        <td><strong><%= p.amount %> €</strong></td>
        <td><%= p.due_date || '-' %></td>
        <td><small><%= p.description || '-' %></small></td>
        <td><a href="/payments/<%= p.id %>" class="btn btn-xs btn-default">Voir</a></td>
      </tr>
      <% }) %>
      <% if (!payments || payments.length === 0) { %>
      <tr><td colspan="7" class="text-center text-success" style="padding:20px"><i class="fa fa-check"></i> Aucun paiement en retard !</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<script src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>
</html>
